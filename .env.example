# ─────────────────────────────────────────────────────────────
#  SPORTZ - הגדרות סביבה
# ─────────────────────────────────────────────────────────────

# כתובת האתר הפומבית (חשוב ל-SEO, sitemap, Open Graph, Google News)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# אימות מול Anthropic - הגדר אחד מהשניים (לא את שניהם):
#
# אפשרות א': מפתח API רגיל (נשלח כ-x-api-key)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
#
# אפשרות ב': Access Token (נשלח כ-Authorization: Bearer).
# מתאים ל-OAuth access token (למשל מ-`ant auth print-credentials --access-token`)
# או לכל bearer token. אם הוא token של OAuth (מתחיל ב-sk-ant-oat) -
# מתווספת אוטומטית כותרת ה-beta הנדרשת.
# ANTHROPIC_AUTH_TOKEN=
#
# כפה התנהגות OAuth (כותרת beta) גם אם ה-token לא מתחיל ב-sk-ant-oat:
# ANTHROPIC_OAUTH=1

# ─────────────────────────────────────────────────────────────
#  בחירת ספק ה-LLM
#  anthropic (ברירת מחדל) = Claude - העברית הכי טובה.
#  openai / minimax        = כל endpoint תואם-OpenAI (MiniMax/DeepSeek/OpenRouter...)
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic

# --- ספק Anthropic (Claude) ---
# המלצה לעברית איכותית: claude-sonnet-4-6 (איזון עלות/איכות),
# claude-opus-4-8 (האיכות המקסימלית), claude-haiku-4-5 (הזול ביותר).
CLAUDE_MODEL=claude-sonnet-4-6

# --- ספק תואם-OpenAI (כשמשתמשים ב-MiniMax / Groq / DeepSeek וכו') ---
# הגדר LLM_PROVIDER=openai ואז אחד מהבאים:
#
# MiniMax:  LLM_BASE_URL=https://api.minimax.io/v1
# Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1   (מהיר וזול - מודלים פתוחים)
#           LLM_MODEL=llama-3.3-70b-versatile  (או meta-llama/llama-4-maverick-17b-128e-instruct,
#                                               moonshotai/kimi-k2-instruct, qwen/qwen3-32b)
# DeepSeek: LLM_BASE_URL=https://api.deepseek.com/v1
#
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=

# סוד לאבטחת נקודת ה-refresh (ה-cron ישתמש בו). הגדר מחרוזת אקראית.
CRON_SECRET=change-me-to-a-random-string

# ─────────────────────────────────────────────────────────────
#  אחסון
#  - DigitalOcean droplet / Docker: אין צורך ב-Upstash. אחסון הקבצים
#    המקומי (.data) נשמר ב-volume מתמשך. השאר ריק.
#  - Vercel (serverless): ה-filesystem אפמרי, ולכן Upstash Redis נדרש.
#    https://upstash.com/  → Create Redis DB → REST API
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# כמה כתבות לייצר בכל ריצה (ברירת מחדל 10) ולכמה זמן אחורה לחפש (שעות)
ARTICLES_PER_RUN=10
LOOKBACK_HOURS=48

# מרווח המתזמן הפנימי (Docker/droplet) במילישניות. ברירת מחדל: 5 דקות.
REFRESH_INTERVAL_MS=300000
