# ─────────────────────────────────────────────────────────────
#  SPORTZ - הגדרות סביבה
# ─────────────────────────────────────────────────────────────

# כתובת האתר הפומבית (חשוב ל-SEO, sitemap, Open Graph, Google News)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# מפתח ה-API של Anthropic (חובה כדי שמנוע הניוז יכתוב כתבות בעברית)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# מודל ה-Claude לשימוש.
# איזון עלות/איכות (ברירת מחדל): claude-sonnet-4-6
# האיכות הגבוהה ביותר (יקר יותר):   claude-opus-4-8
# הזול ביותר (לטריאז'/נפח גבוה):    claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6

# סוד לאבטחת נקודת ה-refresh (ה-cron ישתמש בו). הגדר מחרוזת אקראית.
CRON_SECRET=change-me-to-a-random-string

# ─────────────────────────────────────────────────────────────
#  אחסון (אופציונלי) - Upstash Redis ל-Vercel (serverless)
#  אם לא מוגדר, המערכת תשתמש באחסון קבצים מקומי (.data) -
#  מתאים לפיתוח מקומי בלבד, לא יישמר ב-Vercel.
#  https://upstash.com/  → Create Redis DB → REST API
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# כמה כתבות לייצר בכל ריצה (ברירת מחדל 10) ולכמה זמן אחורה לחפש (שעות)
ARTICLES_PER_RUN=10
LOOKBACK_HOURS=48
