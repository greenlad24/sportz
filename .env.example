# ─────────────────────────────────────────────────────────────
#  SPORTZ - הגדרות סביבה
# ─────────────────────────────────────────────────────────────

# כתובת האתר הפומבית (חשוב ל-SEO, sitemap, Open Graph, Google News)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# אימות מול Anthropic - הגדר אחד מהשניים (לא את שניהם):
#
# אפשרות א': מפתח API רגיל (נשלח כ-x-api-key)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
#
# אפשרות ב': Access Token (נשלח כ-Authorization: Bearer).
# מתאים ל-OAuth access token (למשל מ-`ant auth print-credentials --access-token`)
# או לכל bearer token. אם הוא token של OAuth (מתחיל ב-sk-ant-oat) -
# מתווספת אוטומטית כותרת ה-beta הנדרשת.
# ANTHROPIC_AUTH_TOKEN=
#
# כפה התנהגות OAuth (כותרת beta) גם אם ה-token לא מתחיל ב-sk-ant-oat:
# ANTHROPIC_OAUTH=1

# ─────────────────────────────────────────────────────────────
#  בחירת ספק ה-LLM
#  ברירת המחדל בפרודקשן: Gemini Flash דרך endpoint תואם-OpenAI - חינמי
#  (1,500 בקשות/יום) ועברית מצוינת. שלב הכתיבה הוא הספק היחיד שעולה - ובחינם.
#  anthropic = Claude (איכות גבוהה, בתשלום). openai = כל endpoint תואם-OpenAI.
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openai

# --- ספק תואם-OpenAI: Gemini Flash (ברירת המחדל החינמית) ---
# מפתח חינמי: https://aistudio.google.com/  → "Get API key" (ללא כרטיס אשראי).
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=AIza...
#
# חלופות תואמות-OpenAI (אותו פרוטוקול, שינוי ENV בלבד):
#   Groq:    LLM_BASE_URL=https://api.groq.com/openai/v1   LLM_MODEL=openai/gpt-oss-120b
#            (חינם אך מוגבל ל-~200K טוקנים/יום - לא מספיק לזרם רציף)
#   MiniMax: LLM_BASE_URL=https://api.minimax.io/v1
#   DeepSeek:LLM_BASE_URL=https://api.deepseek.com/v1

# --- ספק Anthropic (Claude) - בתשלום, אופציונלי ---
# הגדר LLM_PROVIDER=anthropic + ANTHROPIC_API_KEY/AUTH_TOKEN למעלה.
# claude-opus-4-8 = העברית האיכותית ביותר. חלופות: claude-sonnet-4-6, claude-haiku-4-5.
CLAUDE_MODEL=claude-opus-4-8

# סוד לאבטחת נקודת ה-refresh (ה-cron ישתמש בו). הגדר מחרוזת אקראית.
CRON_SECRET=change-me-to-a-random-string

# ─────────────────────────────────────────────────────────────
#  אחסון
#  - DigitalOcean droplet / Docker: אין צורך ב-Upstash. אחסון הקבצים
#    המקומי (.data) נשמר ב-volume מתמשך. השאר ריק.
#  - Vercel (serverless): ה-filesystem אפמרי, ולכן Upstash Redis נדרש.
#    https://upstash.com/  → Create Redis DB → REST API
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# כמה אשכולות-מועמדים לכל מחזור תכנון (ברירת מחדל 10) ולכמה אחורה לסרוק (שעות, 24)
ARTICLES_PER_RUN=10
LOOKBACK_HOURS=24
# תקציב טוקנים לכתבה בודדת (כולל "חשיבה" של Flash). ברירת מחדל 8000.
ARTICLE_MAX_TOKENS=8000

# ─────────────────────────────────────────────────────────────
#  מתזמן דו-מחזורי (Docker/droplet), במילישניות
#  - PLAN: שאיבה -> אשכול -> טקסט מלא -> דה-דופ -> הכנסה לתור (כל 15 דק').
#  - WRITE: שולף אשכול אחד מהתור וכותב כתבה (כל 2 דק') -> זרם כתבות רציף.
# ─────────────────────────────────────────────────────────────
PLAN_INTERVAL_MS=900000
WRITE_INTERVAL_MS=120000
# כמה זמן אשכול ממתין בתור לפני שנזרק כ"מעופש" (שעות, ברירת מחדל 6)
QUEUE_TTL_HOURS=6

# ─────────────────────────────────────────────────────────────
#  דה-דופ ברמת נושא (מונע כתבות כפולות, גם ממקורות שונים ובמרווח של ימים)
# ─────────────────────────────────────────────────────────────
# חלון: לא כותבים נושא שכוסה ב-N השעות האחרונות (ברירת מחדל 168 = 7 ימים)
DEDUP_WINDOW_HOURS=168
# סף דמיון (Jaccard) שמעליו שני נושאים נחשבים כפולים (ברירת מחדל 0.5)
DEDUP_SIMILARITY=0.5

# ─────────────────────────────────────────────────────────────
#  מדיה לכתבות (אופציונלי)
# ─────────────────────────────────────────────────────────────
# תמונות: Brave Image Search API (תוצאות מאתרי ארה"ב, עם קרדיט וקישור למקור).
# מפתח חינמי: https://brave.com/search/api/  → Subscriptions → Free
BRAVE_API_KEY=

# וידאו: YouTube Data API v3 - חיפוש סרטון רלוונטי והטמעה בתוך הכתבה.
# מפתח: https://console.cloud.google.com/  → Enable "YouTube Data API v3" → Credentials
YOUTUBE_API_KEY=

# הערה: אין יותר מעבר הגהה/עורך שני (היה בתשלום). תקינות העברית נאכפת ע"י
# "מילון העריכה" (src/lib/dictionary.ts) המוזרק לפרומפט הכותב - הכתבה מוכנה
# לפרסום כבר בקריאה הראשונה. הרחב את המילון עם הזמן (שמות/מונחים שגויים חוזרים).
